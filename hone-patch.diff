+              const note =
+                typeof window !== 'undefined'
+                  ? window.prompt(
+                      'Optional reason (shown to the manager):',
+                      ''
+                    )
+                  : '';
+              if (note === null) return; // cancelled
+              run(
+                'Reject',
+                () =>
+                  api.patch(`/admin/manager-claims/${claim._id}/reject`, {
+                    adminNote: note || '',
+                  }),
+                'Manager claim rejected.'
+              );
+            }}
+            className="btn-ghost text-xs text-red-600"
+          >
+            Reject
+          </button>
+        </div>
+      </div>
+    </div>
+  );
+}

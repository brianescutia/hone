+// Pure unit tests for the domain confidence service. No DB required.
+const test = require('node:test');
+const assert = require('node:assert/strict');
+const {
+  scoreClaim,
+  extractEmailDomain,
+  extractWebsiteDomain,
+  registrableDomain,
+  isFreeProvider,
+} = require('../services/domainConfidence');
+
+test('extractEmailDomain handles common cases', () => {
+  assert.equal(extractEmailDomain('john@almondwood.com'), 'almondwood.com');
+  assert.equal(extractEmailDomain('John@Almondwood.COM'), 'almondwood.com');
+  assert.equal(extractEmailDomain('  jane@foo.co.uk  '), 'foo.co.uk');
+  assert.equal(extractEmailDomain(''), null);
+  assert.equal(extractEmailDomain('noatsign'), null);
+  assert.equal(extractEmailDomain('trailing@'), null);
+  assert.equal(extractEmailDomain(null), null);
+  assert.equal(extractEmailDomain(undefined), null);
+});
+
+test('extractWebsiteDomain strips protocol, www, paths, ports', () => {
+  assert.equal(extractWebsiteDomain('https://www.almondwood.com/contact'), 'almondwood.com');
+  assert.equal(extractWebsiteDomain('http://almondwood.com'), 'almondwood.com');
+  assert.equal(extractWebsiteDomain('almondwood.com'), 'almondwood.com');
+  assert.equal(extractWebsiteDomain('https://leasing.almondwood.com:8080/'), 'leasing.almondwood.com');
+  assert.equal(extractWebsiteDomain(''), null);
+  assert.equal(extractWebsiteDomain(null), null);
+});
+
+test('registrableDomain reduces subdomains', () => {
+  assert.equal(registrableDomain('almondwood.com'), 'almondwood.com');
+  assert.equal(registrableDomain('leasing.almondwood.com'), 'almondwood.com');
+  assert.equal(registrableDomain('a.b.c.almondwood.com'), 'almondwood.com');
+  assert.equal(registrableDomain('foo.co.uk'), 'foo.co.uk');
+  assert.equal(registrableDomain('leasing.foo.co.uk'), 'foo.co.uk');
+});
+
+test('isFreeProvider recognizes common free email hosts', () => {
+  assert.equal(isFreeProvider('gmail.com'), true);
+  assert.equal(isFreeProvider('googlemail.com'), true);
+  assert.equal(isFreeProvider('foo.gmail.com'), true); // reduces to gmail.com
+  assert.equal(isFreeProvider('outlook.com'), true);
+  assert.equal(isFreeProvider('proton.me'), true);
+  assert.equal(isFreeProvider('almondwood.com'), false);
+  assert.equal(isFreeProvider(null), false);
+});
+
+test('scoreClaim: free email provider always low', () => {
+  const s = scoreClaim({
+    workEmail: 'jane@gmail.com',
+    companyWebsite: 'https://almondwood.com',
+  });
+  assert.equal(s.confidence, 'low');
+  assert.equal(s.emailIsFreeProvider, true);
+  assert.equal(s.domainsMatchExactly, false);
+});
+
+test('scoreClaim: exact match → high', () => {
+  const s = scoreClaim({
+    workEmail: 'jane@almondwood.com',
+    companyWebsite: 'https://www.almondwood.com/about',

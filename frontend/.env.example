# Absolute URL of your deployed backend API. Must include /api.
# Either name works — VITE_API_BASE_URL is preferred for new deploys.
VITE_API_BASE_URL=https://hone-production-6f2e.up.railway.app/api
# VITE_API_BASE=  # legacy fallback

# Google OAuth client ID (web). Get from Google Cloud Console.
# Authorized JavaScript origins must include the Vercel URL.
VITE_GOOGLE_CLIENT_ID=

# Set to 'true' to show the demo credentials block on /login and
# /manager-login even in production. Leave blank (or 'false') for real
# deploys. In production the demo box is hidden by default.
VITE_SHOW_DEMO_CREDENTIALS=false

# Optional contact address rendered on static pages.
VITE_SUPPORT_EMAIL=

# ---- Cloudinary (photo uploads) ----
# Required for the PhotoUploader to work. Create a Cloudinary account
# (free tier is fine), then create an UNSIGNED upload preset at:
#   https://console.cloudinary.com/settings/upload
# Recommended preset settings:
#   - Signing Mode: Unsigned
#   - Allowed formats: jpg, jpeg, png, webp, heic, heif
#   - Max file size: 5 MB
#   - Folder: hone/  (optional, keeps uploads organized)
#   - Eager transformations: w_1200,h_900,c_limit,q_auto,f_auto (recommended)
# After saving, copy the preset name (e.g. "hone_unsigned") here.
# DO NOT put CLOUDINARY_API_SECRET in this file — it must never reach the browser.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=hone_unsigned
# Optional: folder to upload into within Cloudinary.
VITE_CLOUDINARY_UPLOAD_FOLDER=hone

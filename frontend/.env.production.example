# Production env template for the hone frontend.
# Vite inlines VITE_* vars at build time. On Vercel/Netlify, set this in the
# project's Environment Variables panel BEFORE triggering the production build.

# Absolute URL of your deployed backend API. Must include the /api prefix
# because the frontend code calls e.g. `${VITE_API_BASE}/auth/login`.
VITE_API_BASE=https://api.hone.app/api

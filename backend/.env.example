# ---- Database ----
# Leave MONGO_URI empty to use in-memory MongoDB (good for first-time setup).
# Set it to use a real local Mongo:
#   MONGO_URI=mongodb://localhost:27017/hone
# In production, MONGO_URI is REQUIRED — the server will refuse to boot
# without it and will not fall back to the in-memory database.
MONGO_URI=

# ---- Auth ----
# Long random string (≥ 16 chars; ≥ 48 recommended). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string

# ---- HTTP ----
PORT=5050
# Single allowed origin (legacy). Use CLIENT_ORIGINS for multiple.
CLIENT_ORIGIN=http://localhost:5173
# Comma-separated allowed origins (preferred).
# CLIENT_ORIGINS=http://localhost:5173,https://hone.vercel.app

# ---- Email (Resend) ----
# When RESEND_API_KEY is set, verification emails are sent for real.
# Otherwise the verification URL is logged to the server console and
# returned in the /auth/register response as `devVerifyUrl` so the dev
# UI can show a clickable link.
RESEND_API_KEY=
# Must be a verified sender in your Resend dashboard.
EMAIL_FROM=hone <no-reply@hone.local>

# ---- External imports (Apify) ----
# OPTIONAL. If left blank, the admin External Leads queue still works for
# manually-imported leads (POST /api/admin/external-leads/import) — but
# the "Run Apify" button is disabled.
#
# Scraped data is NEVER auto-published. Imports require admin approval.
APIFY_TOKEN=
APIFY_FACEBOOK_MARKETPLACE_ACTOR_ID=
APIFY_ZILLOW_ACTOR_ID=

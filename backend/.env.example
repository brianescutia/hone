# ---- Database ----
# Leave MONGO_URI empty in dev to use in-memory MongoDB.
# In production, MONGO_URI is REQUIRED — the server will refuse to boot
# without it and will not fall back to the in-memory database.
MONGO_URI=

# ---- Auth ----
# Long random string (≥ 16 chars; ≥ 48 recommended).
JWT_SECRET=replace-this-with-a-long-random-string

# ---- HTTP / CORS ----
PORT=5050
NODE_ENV=development

# Comma-separated allowed origins. Either CLIENT_ORIGIN (legacy) or
# CLIENT_ORIGINS (preferred). Local dev origins are always allowed
# automatically in NODE_ENV=development.
CLIENT_ORIGIN=https://hone-olive.vercel.app,http://localhost:5173
# CLIENT_ORIGINS=https://hone-olive.vercel.app,http://localhost:5173

# Allow any *.vercel.app preview deploy through CORS (convenient for staging).
ALLOW_VERCEL_PREVIEWS=false

# ---- Google OAuth (student verification) ----
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
#   - Application type: Web application
#   - Authorized JavaScript origins:
#       http://localhost:5173
#       https://hone-olive.vercel.app
#   - Authorized redirect URIs (only needed for redirect flow; we use ID-token
#     flow so these are optional but harmless to set):
#       http://localhost:5050/api/auth/google/callback
#       https://hone-production-6f2e.up.railway.app/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# ---- Email (Resend) — optional ----
# Without RESEND_API_KEY, verification emails are logged to the server console.
# Student verification no longer relies on email links (Google handles it),
# but managers still get email-link verification if Resend is configured.
RESEND_API_KEY=
EMAIL_FROM=hone <no-reply@hone.local>
SUPPORT_EMAIL=

# ---- Seeding ----
# Auto-seed the in-memory DB in dev. Set to 'true' to seed a real DB
# (only useful for staging — MUST be 'false' in public-facing prod).
# In production this is the only switch that enables creating the
# password123 demo accounts. Keep it false.
SEED_DEMO_DATA=false

# ---- Demo / admin provisioning ----
# Used by scripts/createAdmin.js (npm run create-admin).
# Do NOT commit a populated copy of this file.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=

# Used by scripts/createManager.js (npm run create-manager).
MANAGER_EMAIL=
MANAGER_PASSWORD=
MANAGER_NAME=
MANAGER_COMPANY=
# 'approved' | 'pending' | 'rejected'. Default is 'pending' in production.
MANAGER_STATUS=

# ---- Feature flags (manager/property claim system) ----
# When true, sublease posts from verified UC Davis students bypass the
# moderation queue and go live immediately. Off by default so a
# moderator can vet the first wave of student posts. Recommended for
# production: true (after the first wave is reviewed manually).
AUTO_APPROVE_VERIFIED_STUDENT_SUBLEASES=false

# When true, a verified manager's edits to their claimed listing are
# applied immediately (no second admin review per edit). Off by default —
# admin should vet the first round of manager-driven edits, then flip
# this on. Recommended for production: true.
MANAGER_AUTO_APPROVE_CLAIMED_LISTING_UPDATES=false

# ---- Cloudinary (photo uploads) — optional but strongly recommended ----
# Photo uploads on hone use a Cloudinary unsigned upload preset. The
# CLOUD_NAME and UPLOAD_PRESET below are also exposed to the frontend as
# VITE_CLOUDINARY_CLOUD_NAME / VITE_CLOUDINARY_UPLOAD_PRESET (frontend env).
# API_KEY/API_SECRET are ONLY needed if you later add signed uploads server-side.
# NEVER expose CLOUDINARY_API_SECRET to the browser.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=hone_unsigned
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- External imports (Apify) — optional, not used in this pass ----
APIFY_TOKEN=
APIFY_FACEBOOK_MARKETPLACE_ACTOR_ID=
APIFY_ZILLOW_ACTOR_ID=

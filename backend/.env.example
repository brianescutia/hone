# ---- Database ----
# Leave MONGO_URI empty in dev to use in-memory MongoDB.
# In production, MONGO_URI is REQUIRED — the server will refuse to boot
# without it and will not fall back to the in-memory database.
MONGO_URI=

# ---- Auth ----
# Long random string (≥ 16 chars; ≥ 48 recommended).
JWT_SECRET=replace-this-with-a-long-random-string

# ---- HTTP / CORS ----
PORT=5050
NODE_ENV=development

# Comma-separated allowed origins. Either CLIENT_ORIGIN (legacy) or
# CLIENT_ORIGINS (preferred). Local dev origins are always allowed
# automatically in NODE_ENV=development.
CLIENT_ORIGIN=https://hone-olive.vercel.app,http://localhost:5173
# CLIENT_ORIGINS=https://hone-olive.vercel.app,http://localhost:5173

# Allow any *.vercel.app preview deploy through CORS (convenient for staging).
ALLOW_VERCEL_PREVIEWS=false

# ---- Google OAuth (student verification) ----
# Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
#   - Application type: Web application
#   - Authorized JavaScript origins:
#       http://localhost:5173
#       https://hone-olive.vercel.app
#   - Authorized redirect URIs (only needed for redirect flow; we use ID-token
#     flow so these are optional but harmless to set):
#       http://localhost:5050/api/auth/google/callback
#       https://hone-production-6f2e.up.railway.app/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# ---- Email (Resend) — optional ----
# Without RESEND_API_KEY, verification emails are logged to the server console.
# Student verification no longer relies on email links (Google handles it),
# but managers still get email-link verification if Resend is configured.
RESEND_API_KEY=
EMAIL_FROM=hone <no-reply@hone.local>
SUPPORT_EMAIL=

# ---- Seeding ----
# Auto-seed the in-memory DB in dev. Set to 'true' to seed a real DB
# (only useful for staging — leave 'false' for public-facing prod).
SEED_DEMO_DATA=false

# ---- External imports (Apify) — optional, not used in this pass ----
APIFY_TOKEN=
APIFY_FACEBOOK_MARKETPLACE_ACTOR_ID=
APIFY_ZILLOW_ACTOR_ID=

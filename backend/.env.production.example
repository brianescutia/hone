# Production env template for the hone backend.
# Copy to your hosting provider's secret store (Render/Railway/Fly env vars,
# Vercel project env, etc.) — DO NOT commit a populated copy of this file.

NODE_ENV=production

# Long random string (≥ 48 hex chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# The backend will REFUSE TO BOOT in production if this is missing or too short.
JWT_SECRET=

# MongoDB Atlas SRV URI. Get this from Atlas → Database → Connect → Drivers.
# REQUIRED in production — the in-memory fallback is disabled.
# Make sure your hosting provider's egress IP is allowed in Atlas Network Access.
MONGO_URI=mongodb+srv://USER:PASS@cluster0.example.mongodb.net/hone?retryWrites=true&w=majority

# Comma-separated list of allowed CORS origins (no trailing slashes).
# Add every frontend URL you serve from: prod, staging, custom domain.
CLIENT_ORIGINS=https://hone.app,https://www.hone.app

# Optional: allow any *.vercel.app preview deploy through CORS.
# Convenient for staging; turn off once you have a stable preview domain.
ALLOW_VERCEL_PREVIEWS=false

# Port the host expects you to bind to. Render/Railway/Fly set this for you.
PORT=5050

# ---- Email (Resend) ----
# REQUIRED for production — without it, signup verification emails are
# logged to the server console and users will never see them.
RESEND_API_KEY=re_your_resend_api_key
# Must be a domain verified in your Resend dashboard.
EMAIL_FROM=hone <no-reply@your-verified-domain.com>

# ---- External imports (Apify) — OPTIONAL ----
# Leave blank to disable Apify imports. The admin External Leads queue
# still works for manually-imported leads.
APIFY_TOKEN=
APIFY_FACEBOOK_MARKETPLACE_ACTOR_ID=
APIFY_ZILLOW_ACTOR_ID=
